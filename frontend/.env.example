VITE_API_URL=https://buffetvip-backend.onrender.com/api
VITE_CRISP_WEBSITE_ID=

# Firebase Phone Authentication (OTP số điện thoại khách hàng).
# Lấy các giá trị này tại Firebase Console > Project settings > General >
# "Your apps" > Web app (tạo mới nếu chưa có). Đây KHÔNG phải secret theo
# nghĩa thông thường — Firebase Web API Key được thiết kế để nằm trong mã
# nguồn frontend công khai, bảo mật thực sự nằm ở Firebase Security Rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
